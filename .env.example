# Copy to .env for local development
# These are set automatically in Replit; only needed for running outside Replit.

# Postgres connection string (Replit provides this automatically)
DATABASE_URL=postgres://user:password@localhost:5432/finbridge

# Express session secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# In production, lock down CORS to your Vercel frontend URL
# CORS_ORIGIN=https://finbridge.vercel.app

# Set to "production" when deploying
NODE_ENV=development
